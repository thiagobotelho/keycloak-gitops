# Ambiente usado no CRC local; o namespace continua keycloak-dev por
# compatibilidade com os manifests e secrets existentes.
ENVIRONMENT=desenvolvimento
NAMESPACE=keycloak-dev

# Senhas dos usuários criados no realm observability pelo keycloak-config-cli.
# Não versionar valores reais. Se vazio no script, serão geradas automaticamente.
GRAFANA_ADMIN_PASSWORD=
ZABBIX_ADMIN_PASSWORD=
OBSERVABILITY_ADMIN_PASSWORD=
